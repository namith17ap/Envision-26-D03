#include <Adafruit_LiquidCrystal.h>
Adafruit_LiquidCrystal lcd(0);
int pin1=9;
int pin2=7;
int pin3=5;
int pin4=3;
int num1,num2;

void setup() {
  Serial.begin(9600);
  lcd.begin(16, 2);
  lcd.setBacklight(HIGH);
  lcd.print("hello, world!");
  delay(2000);
  lcd.clear();
  
  pinMode(pin1, OUTPUT);
  pinMode(pin2, OUTPUT);
  pinMode(pin3, OUTPUT);
  pinMode(pin4, OUTPUT);
  


}

void loop() {
  Serial.println("Enter your number1: ");
  while(Serial.available()==0){
  }
  num1=Serial.parseInt();
  Serial.println(num1);
  Serial.println("Enter your number2: ");
  while(Serial.available()==0){
  }
  num2=Serial.parseInt();
  Serial.println(num2);
  int stat1,stat2,stat3,stat4;
  int num3=num1+num2;
  if(num3>15){
    lcd.print("OVERFLOW!!");
    delay(4000);
  }
  else{
    stat4=num3/8;
    int rem1=num3%8;
    stat3=rem1/4;
    int rem2=rem1%4;
    stat2=rem2/2;
    int rem3=rem2%2;
    stat1=rem3;
    if(stat1==1){
      digitalWrite(pin1,HIGH);
    }
    else{
      digitalWrite(pin1,LOW);
    }
    if(stat2==1){
      digitalWrite(pin2,HIGH);
    }
    else{
      digitalWrite(pin2,LOW);
    }
    if(stat3==1){
      digitalWrite(pin3,HIGH);
    }
    else{
      digitalWrite(pin3,LOW);
    }
    if(stat4==1){
      digitalWrite(pin4,HIGH);
    }
    else{
      digitalWrite(pin4,LOW);
    }
    lcd.print("SUM IS :");
    lcd.setCursor(0,1);
    lcd.print(num3);
    delay(5000);
    lcd.clear();
    
} 
  lcd.clear();
  digitalWrite(pin1,LOW);
  digitalWrite(pin2,LOW);
  digitalWrite(pin3,LOW);
  digitalWrite(pin4,LOW);
  
}